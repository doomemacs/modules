;; -*- mode: lisp-data -*-
"3.0.0"
((name :lang org)

 (flags +crypt
        +dragndrop
        +gnuplot
        +journal
        +jupyter
        +noter
        +pandoc
        +present
        +pretty
        +roam)

 (obsolete
  (+ipython   ()    "24.08")
  (+pomodoro  ()    "25.04")
  (+contacts  ()    "25.04")
  (+hugo      ()    "25.04")
  (+passwords ()    "25.04")
  (+roam2     +roam "25.09")
  (+brain     ()    "26.02"))

 ;; TODO: Fix :pin's when in v3
 ;; TODO: Remove packages.el
 (packages
  (org :host github
       ;; REVIEW: I intentionally avoid git.savannah.gnu.org because of SSL
       ;;   issues (see #5655), uptime issues, download time, and lack of
       ;;   shallow clone support.
       :repo "emacs-straight/org-mode"
       :files (:defaults "etc")
       :depth 1
       ;; HACK: Org has a post-install step that generates org-version.el and
       ;;   org-loaddefs.el, but Straight doesn't invoke this step, and the
       ;;   former doesn't work if the Org repo is a shallow clone.  Rather than
       ;;   impose the network burden of a full clone (and other redundant and
       ;;   platform unagnostic work in Org's makefile), I'd rather fake these
       ;;   files instead. Besides, Straight already produces a
       ;;   org-autoloads.el, so org-loaddefs.el isn't needed.
       :patches ("001-org-version-and-loaddefs.patch")
       ;; HACK: Org is hardcoded (with file-local variables) to spew some of its
       ;;   autoloads into org-loaddefs.el file (that is never loaded or
       ;;   subsumed into Doom's package autoloads), while the rest go into
       ;;   org-autoloads.el, so we have to manually merge them.
       ;; REVIEW: Fix this upstream?
       :post-build
       (copy-file "org-loaddefs.el" (straight--autoloads-file "org"))
       :tag "release_9.8.4"
       :env `((org--inhibit-version-check . t)))
  (org-contrib :host github
               :repo "emacsmirror/org-contrib"
               :pin "b840bdabd1867f9d51ee36bef7bac4be7073288c")

  (avy)
  (htmlize :pin "fa644880699adea3770504f913e6dddbec90c076")
  (ox-clip :pin "a549cc8e1747beb6b7e567ffac27e31ba45cb8e8")
  (toc-org :pin "6d3ae0fc47ce79b1ea06cabe21a3c596395409cd")
  (org-cliplink :pin "13e0940b65d22bec34e2de4bc8cba1412a7abfbc")
  ((:if (and (featurep :system 'macos)
             (modulep! :os macos)))
   (org-mac-link :pin "e30171a6e98db90787ab8a23b3a7dc4fd13b10f9"))
  ((:if (modulep! :editor evil +everywhere))
   (evil-org :host github
             :repo "doomelpa/evil-org-mode"
             :pin "06518c65ff4f7aea2ea51149d701549dcbccce5d"))
  ((:if (modulep! +dragndrop))
   (org-download))
  ((:if (modulep! +gnuplot))
   (gnuplot)
   (gnuplot-mode))
  ((:if (modulep! +jupyter))
   (jupyter))
  ((:if (modulep! +journal))
   (org-journal))
  ((:if (modulep! +noter))
   (org-noter))
  ((:if (modulep! +pretty))
   (org-modern)
   (org-appear))
  ((:if (modulep! +present))
   (centered-window)
   (org-tree-slide)
   (org-re-reveal)
   (revealjs))
  ((:if (or (modulep! +roam)
            (modulep! +roam2)))
   (org-roam))

  ;; Babel
  (ob-async)
  (ob-crystal    :if (modulep! :lang crystal))
  (ob-elixir     :if (modulep! :lang elixir))
  (ob-fsharp     :if (modulep! :lang fsharp))
  (ob-go         :if (modulep! :lang go))
  (ob-graphql    :if (modulep! :lang graphql))
  (ob-hy         :if (modulep! :lang hy))
  (ob-nim        :if (modulep! :lang nim))
  (ob-php        :if (modulep! :lang php))
  (ob-racket     :if (modulep! :lang racket))
  (ob-restcilent :if (modulep! :lang rest))
  (ob-ammonite   :if (modulep! :lang scala))

  ;; Export
  (ox-pandoc
   :if (modulep! +pandoc)
   :pin "1caeb56a4be26597319e7288edbc2cabada151b4")
  (ox-rst
   :if (modulep! :lang rst)
   :pin "b73eff187eebac24b457688bfd27f09eff434860"))

 ;; TODO: Remove doctor.el
 (checks
  ((modulep! +uv)
   (check :executable? "gnuplot"
          :for "Generating diagrams with org-plot/gnuplot.el"))
  ((modulep! +roam)
   (check :executable? "dot"
          :for "Generating graph visualizations with org-roam"))
  ((modulep! +dragndrop)
   (cond
    ((featurep :system 'macos)
     (check :executable? "pngpaste"
            :for "Saving screenshots to clipboard with `org-download-clipboard'"))
    ((featurep :system 'linux)
     (check :executable? '("maim" "scrot" "gnome-screenshot")
            :for "Taking screenshots with `org-download-clipboard'")
     (check :executable?
            (if (string= "wayland" (getenv "XDG_SESSION_TYPE")) "wl-paste" "xclip")
            :for "Copying attachments to clipboard via `org-download-clipboard'"))
    ((featurep :system 'windows)
     (check :executable? "convert"
            :for "Converting images generated by `org-download-clipboard'"))))))
