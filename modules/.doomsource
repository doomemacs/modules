;; -*- mode: lisp-data -*-
"2.2.0"
((name . doom+)
 (requires
  (emacs ">=29.1")
  (doom ">=2.2.0"))
 (obsolete
  ;; From pre-v2.0
  ((:feature version-control) (:emacs vc :ui vc-gutter) "2.0")
  ((:feature spellcheck)      (:checkers spell)         "2.0")
  ((:feature syntax-checker)  (:checkers syntax)        "2.0")
  ((:feature evil)            (:editor evil)            "2.0")
  ((:feature snippets)        (:editor snippets)        "2.0")
  ((:feature file-templates)  (:editor file-templates)  "2.0")
  ((:feature workspaces)      (:ui workspaces)          "2.0")
  ((:feature eval)            (:tools eval)             "2.0")
  ((:feature lookup)          (:tools lookup)           "2.0")
  ((:feature debugger)        (:tools debugger)         "2.0")
  ((:tools rotate-text)       (:editor rotate-text)     "2.0")
  ((:tools vterm)             (:term vterm)             "2.0")
  ((:tools password-store)    (:tools pass)             "2.0")
  ((:tools flycheck)          (:checkers syntax)        "2.0")
  ((:tools flyspell)          (:checkers spell)         "2.0")
  ((:tools macos)             (:os macos)               "2.0")
  ((:emacs electric-indent)   (:emacs electric)         "2.0")
  ((:emacs hideshow)          (:editor fold)            "2.0")
  ((:emacs eshell)            (:term eshell)            "2.0")
  ((:emacs term)              (:term term)              "2.0")
  ((:ui doom-modeline)        (:ui modeline)            "2.0")
  ((:ui fci)                  (:ui fill-column)         "2.0")
  ((:ui evil-goggles)         (:ui ophints)             "2.0")
  ((:ui tabbar)               (:ui tabs)                "2.0")
  ((:ui pretty-code)          (:ui ligatures)           "2.0")
  ((:app email)               (:email mu4e)             "2.0")
  ((:app notmuch)             (:email notmuch)          "2.0")
  ((:lang perl)               (:lang raku)              "2.0")

  ;; Post-v2.2
  ((:ui doom-dashboard)       (:ui dashboard)           "2.1")))
